<!DOCTYPE html>
<html>
<head>
<title>Student Result Portal</title>

<style>
body{
font-family: Arial;
text-align:center;
background:#f2f2f2;
}

.container{
background:white;
padding:20px;
width:350px;
margin:100px auto;
border-radius:10px;
box-shadow:0 0 10px gray;
}

input{
padding:10px;
width:80%;
margin:10px;
}

button{
padding:10px 20px;
background:blue;
color:white;
border:none;
cursor:pointer;
}

#result{
margin-top:20px;
font-weight:bold;
}
</style>

</head>

<body>

<div class="container">

<h2>Student Result Portal</h2>

<input type="text" id="roll" placeholder="Enter Roll Number">

<br>

<button onclick="checkResult()">Submit</button>

<div id="result"></div>

</div>

<script>

const students = {
"101": {name:"Rahul", maths:88, science:91, english:85},
"102": {name:"Priya", maths:78, science:80, english:82},
"103": {name:"Amit", maths:90, science:87, english:89}
};

function checkResult(){

let roll = document.getElementById("roll").value;

if(students[roll]){

let s = students[roll];

document.getElementById("result").innerHTML =
"Name: " + s.name + "<br>" +
"Maths: " + s.maths + "<br>" +
"Science: " + s.science + "<br>" +
"English: " + s.english;

}

else{

document.getElementById("result").innerHTML = "Result Not Found";

}

}

</script>

</body>
</html>
